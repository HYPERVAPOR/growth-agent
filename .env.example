# GitHub Configuration
GITHUB_TOKEN=your_token_here
REPO_PATH=owner/repo

# Data API Keys
X_RAPIDAPI_KEY=your_key_here
X_RAPIDAPI_HOST=twitter241.p.rapidapi.com

# LLM Configuration
OPENROUTER_API_KEY=sk-...

# Workflow Configuration
DATA_ROOT=data
CURATION_MIN_SCORE=60
CURATION_TOP_K=10
MAX_CURATE_ITEMS=30
BLOG_GENERATION_ENABLED=true

# Inbox Selection Strategy
# Options: recent_first (推荐), random, balanced, chronological (原始)
# - recent_first: 按发布时间降序，评估最新内容
# - random: 随机采样，完全公平
# - balanced: 按来源分组采样，保证多样性
# - chronological: 按写入顺序（原始行为）
SELECTION_STRATEGY=recent_first
MAX_ITEMS_PER_SOURCE_SELECTION=3

# Ingestion Limits
MAX_ITEMS_PER_SOURCE=5

# LLM Settings
LLM_MODEL=anthropic/claude-3.5-sonnet
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# LanceDB Configuration
USE_LANCEDB=false
LANCEDB_URI=data/index/.lancedb

# Scheduler Settings
SCHEDULER_TIMEZONE=Asia/Shanghai
INGESTION_SCHEDULE=0 8 * * *

# Google Search Console Configuration
GSC_ENABLED=false
GSC_SITE_URL=https://example.com

# Option 1: Use service account file
GSC_SERVICE_ACCOUNT_PATH=path/to/service-account.json

# Option 2: Use environment variables (recommended for Next.js/Vercel deployments)
GSC_CLIENT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com
GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# PostHog Configuration
POSTHOG_ENABLED=false
POSTHOG_API_KEY=phc_your_key_here
POSTHOG_HOST=app.posthog.com
POSTHOG_PROJECT_ID=your_project_id

# Workflow C Scheduling
GSC_SCHEDULE=0 9 * * *
POSTHOG_SCHEDULE=0 */6 * * *

# Prompt Templates
PROMPTS_DIR=prompts *
